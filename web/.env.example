# better-auth（本番では BETTER_AUTH_SECRET を必ず設定：32文字以上）
# 生成例: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-32+char-random-string
BETTER_AUTH_URL=http://localhost:3000
# SQLite（認証テーブル + Notion資格情報を格納。永続化とバックアップ必須）
DATABASE_PATH=data/app.sqlite

# 初期管理者 seed（scripts/seed-admin.ts で使用）
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me

# Notion 資格情報の暗号化鍵（Phase 2 で使用。AES-256 のため必ず32バイト）
CRYPTO_KEY=change-me-exactly-32-bytes-000000

# Cloudflare Turnstile（Phase 1後続でcaptcha有効化。未設定ならCAPTCHA無効）
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=
