# better-auth（本番では必ず設定：32文字以上のランダム文字列）
# 生成例: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-32+char-random-string
BETTER_AUTH_URL=http://localhost:3000

# SQLite（認証テーブル + Notion資格情報）。本番は必ず絶対パスを実環境変数で渡す。
# バックアップ対象もこの絶対パスに固定する。
# 例: /var/lib/notion-invoice/app.sqlite
DATABASE_PATH=/var/lib/notion-invoice/app.sqlite

# 初期管理者 seed（scripts/seed-admin.ts で使用）
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me

# Notion 資格情報の暗号化鍵（AES-256）。本番では必須・32文字以上。
# プレースホルダのまま使わないこと。生成例: openssl rand -base64 32
CRYPTO_KEY=change-me-to-a-32+char-random-string

# Cloudflare Turnstile（Phase 1b でcaptcha有効化。未設定ならCAPTCHA無効）
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=
